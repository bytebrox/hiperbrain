{
  "name": "hiperbrain",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build:core && next dev",
    "build": "npm run build:core && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:core": "npm run build --workspace @hiperbrain/core",
    "test:core": "npm run test --workspace @hiperbrain/core",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build:core && changeset publish"
  },
  "dependencies": {
    "@hiperbrain/core": "*",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.108.1",
    "bs58": "^6.0.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tweetnacl": "^1.0.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
