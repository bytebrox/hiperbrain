# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# one-off DB seeding / maintenance scripts (not needed by the app at runtime).
# The automated Wikidata ingestor + its shared helper ARE tracked, because the
# nightly "seed-brain" GitHub Action checks them out and runs them in CI.
/scripts/*
!/scripts/seed-wikidata.mjs
!/scripts/lib
/scripts/lib/*
!/scripts/lib/ingest.mjs

# marketing material (not part of the app)
/marketing/

# typescript
*.tsbuildinfo
next-env.d.ts

# monorepo package build outputs
/packages/*/dist
/packages/*/node_modules
