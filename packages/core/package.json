{
  "name": "@hiperbrain/core",
  "version": "0.4.0",
  "description": "Hyperdimensional Computing (HDC / VSA) engine: bind, bundle, permute, cleanup memory, one-shot learning and analogical reasoning. Zero dependencies; runs in the browser, Node, Edge, Deno and Bun.",
  "license": "MIT",
  "author": "hiperbrain",
  "homepage": "https://www.hiperbrain.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bytebrox/hiperbrain.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/bytebrox/hiperbrain/issues"
  },
  "keywords": [
    "hdc",
    "vsa",
    "hyperdimensional-computing",
    "vector-symbolic-architecture",
    "associative-memory",
    "analogy",
    "one-shot-learning",
    "neuro-symbolic",
    "ai",
    "embeddings"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
